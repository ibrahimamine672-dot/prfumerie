# ─────────────────────────────────────────────────────────────────────────────
# Test environment variables
# ─────────────────────────────────────────────────────────────────────────────
# This file documents the env vars used by integration tests.
# They are set programmatically in tests/testUtils.js – this file is a
# reference only.  However, you may load it in jest.config.js with:
#
#   require('dotenv').config({ path: '.env.test' });
#
# ── JWT ────────────────────────────────────────────────────────────────────
# Must be at least 32 characters long (the app enforces this at startup).
JWT_SECRET=test-jwt-secret-key-not-for-production-12345

# ── MongoDB ────────────────────────────────────────────────────────────────
# Overridden at runtime by mongodb-memory-server — this is just a placeholder.
# MONGODB_URI=mongodb://127.0.0.1:27017/parfum-test

# ── Admin account (used by config/admin.js for migration tests) ────────────
ADMIN_EMAIL=test-admin@example.com
ADMIN_PASSWORD=test-admin-password-123
ADMIN_NAME=Test Admin
ADMIN_PHONE=+212600000000
ADMIN_LOCATION=Casablanca, Morocco
